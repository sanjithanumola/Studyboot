rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notes
    // Fields: id, uid, title, content, subject, color, createdAt
    //
    // Collection: flashcards
    // Fields: id, uid, front, back, subject, createdAt
    //
    // Collection: planner
    // Fields: id, uid, day, subject, status, createdAt
    //
    // Collection: users
    // Fields: uid, displayName, email, photoURL, streak, totalStudyTime, lastStudyDate
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidNote(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() < 10000 &&
             data.subject is string && data.uid == request.auth.uid;
    }

    function isValidFlashcard(data) {
      return data.front is string && data.front.size() > 0 && data.front.size() < 1000 &&
             data.back is string && data.back.size() > 0 && data.back.size() < 2000 &&
             data.uid == request.auth.uid;
    }

    function isValidPlan(data) {
      return data.day is string && data.subject is string && 
             data.status in ['completed', 'pending'] &&
             data.uid == request.auth.uid;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.streak is number &&
             data.totalStudyTime is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNote(request.resource.data);
      allow update: if isDocOwner() && isValidNote(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /flashcards/{cardId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidFlashcard(request.resource.data);
      allow update: if isDocOwner() && isValidFlashcard(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /planner/{planId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidPlan(request.resource.data);
      allow update: if isDocOwner() && isValidPlan(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
